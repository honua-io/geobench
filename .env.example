# GeoBench environment configuration
# Copy to .env and adjust as needed.

# Docker images (pin versions for reproducibility)
POSTGIS_IMAGE=postgis/postgis:17-3.5
HONUA_IMAGE=honuaio/honua-server:latest
GEOSERVER_IMAGE=docker.osgeo.org/geoserver:2.28.0
QGIS_IMAGE=qgis/qgis-server:3.38
K6_IMAGE=grafana/k6:0.54.0

# Host port mappings
POSTGIS_PORT=25432
HONUA_PORT=8081
GEOSERVER_PORT=8082
QGIS_PORT=8083

# Credentials
HONUA_ADMIN_PASSWORD=geobench-admin-key
GEOSERVER_ADMIN_PASSWORD=geoserver

# Benchmark settings (used by run-benchmark.sh)
RUNS=5
SERVERS="honua geoserver qgis"
